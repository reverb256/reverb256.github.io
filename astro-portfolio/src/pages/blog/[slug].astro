---
import Layout from "../../layouts/Layout.astro";

// Generate static paths with posts defined inline
export function getStaticPaths() {
  const posts = [
    "privacy-first-ai-gateway",
    "food-service-to-rust",
    "nixos-cluster-colmena",
    "frostbite-gazette-overview"
  ];
  return posts.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Post data
const getPostData = (slug: string) => {
  const postData: Record<string, any> = {
    "privacy-first-ai-gateway": {
      title: "Building a Privacy-First AI Gateway on NixOS",
      date: "2026-03-08",
      tags: ["NixOS", "AI", "Privacy"]
    },
    "food-service-to-rust": {
      title: "From Food Service to Rust: My Dev Journey",
      date: "2026-02-15",
      tags: ["Career", "Learning", "Rust"]
    },
    "nixos-cluster-colmena": {
      title: "Managing a 4-Host NixOS Cluster with Colmena",
      date: "2026-01-20",
      tags: ["NixOS", "Infrastructure", "Colmena"]
    },
    "frostbite-gazette-overview": {
      title: "Frostbite Gazette: AI-Curated Canadian Journalism",
      date: "2026-03-01",
      tags: ["Astro", "Cloudflare", "AI"]
    }
  };
  return postData[slug] || {
    title: "Coming Soon",
    date: "",
    tags: []
  };
};

const post = getPostData(slug);

// Generate unique description per post
const getPostDescription = (slug: string, title: string) => {
  const descriptions: Record<string, string> = {
    "privacy-first-ai-gateway": "How I built a local LLM stack with Claude-compatible APIs on NixOS, reducing cloud dependencies while maintaining full control over my AI development workflow.",
    "food-service-to-rust": "After 15 years in restaurants, I pivoted to software development. Here's how AI-assisted learning and hands-on building accelerated my transition into tech.",
    "nixos-cluster-colmena": "Lessons learned from deploying NixOS across four machines with GPU mining workloads and AI inference services using Colmena multi-host deployment.",
    "frostbite-gazette-overview": "Building an automated news platform that filters 40+ RSS feeds through Groq AI for relevance, accountability, and Canadian focus on journalism."
  };
  return descriptions[slug] || `Blog post about ${title}. Technical writing on development, infrastructure, and AI.`;
};

const postDescription = getPostDescription(slug, post.title);
const allPosts = {
  "privacy-first-ai-gateway": { title: "Building a Privacy-First AI Gateway on NixOS" },
  "food-service-to-rust": { title: "From Food Service to Rust: My Dev Journey" },
  "nixos-cluster-colmena": { title: "Managing a 4-Host NixOS Cluster with Colmena" },
  "frostbite-gazette-overview": { title: "Frostbite Gazette: AI-Curated Canadian Journalism" }
};
---

<Layout
  title={`${post.title} | Blog`}
  description={postDescription}
>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <div data-animate="fade-up">
      <a href="/blog" class="text-sm text-[var(--base0D)] hover:underline mb-4 inline-block">← Back to Blog</a>
      <h1 class="text-4xl font-bold mb-4 text-[var(--base07)]">{post.title}</h1>
      <div class="flex items-center gap-4 text-sm text-[var(--base04)] mb-8">
        <span>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        {post.tags.map((tag: string) => (
          <span class="text-[var(--base09)]">#{tag}</span>
        ))}
      </div>
    </div>

    <div class="glass p-8" data-animate="fade-up" data-delay="0.2">
      <p class="text-lg text-[var(--base05)] mb-6">
        This post is coming soon! I'm building in public, which means writing about what I'm learning as I learn it.
      </p>
      <p class="text-sm text-[var(--base04)] mb-6">
        In the meantime, check out the <a href="/#projects" class="text-[var(--base0D)] hover:underline">projects</a> I'm working on, or see <a href="/now" class="text-[var(--base0D)] hover:underline">what I'm focused on right now</a>.
      </p>
      <div class="border-l-2 border-[var(--base02)] pl-4 mt-6">
        <p class="text-sm text-[var(--base05)] italic">
          "The best way to learn is to build things. The second best way is to write about what you're building."
        </p>
      </div>
    </div>

    <div class="glass p-6 mt-12" data-animate="fade-up" data-delay="0.4">
      <h3 class="text-sm font-bold text-[var(--base07)] mb-2">More Posts</h3>
      <div class="space-y-2">
        {Object.entries(allPosts).map(([slug, data]) => (
          <a href={`/blog/${slug}`} class="block text-sm text-[var(--base05)] hover:text-[var(--base0D)] transition-colors">
            {data.title}
          </a>
        ))}
      </div>
    </div>
  </article>
</Layout>

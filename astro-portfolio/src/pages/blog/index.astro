---
import Layout from "../../layouts/Layout.astro";

// Sample blog posts - in production these would come from content collection
const posts = [
  {
    title: "Building a Privacy-First AI Gateway on NixOS",
    date: "2026-03-08",
    excerpt: "How I built a local LLM stack with Claude-compatible APIs, reducing cloud dependencies while maintaining full control over my AI development workflow.",
    tags: ["NixOS", "AI", "Privacy"],
    slug: "privacy-first-ai-gateway",
    readTime: 8,
    featured: true
  },
  {
    title: "From Food Service to Rust: My Dev Journey",
    date: "2026-02-15",
    excerpt: "After 15 years in restaurants, I pivoted to software development. Here's how AI-assisted learning and hands-on building accelerated my transition.",
    tags: ["Career", "Learning", "Rust"],
    slug: "food-service-to-rust",
    readTime: 6,
    featured: false
  },
  {
    title: "Managing a 4-Host NixOS Cluster with Colmena",
    date: "2026-01-20",
    excerpt: "Lessons learned from deploying NixOS across four machines with GPU mining workloads and AI inference services.",
    tags: ["NixOS", "Infrastructure", "Colmena"],
    slug: "nixos-cluster-colmena",
    readTime: 10,
    featured: false
  },
  {
    title: "Frostbite Gazette: AI-Curated Canadian Journalism",
    date: "2026-03-01",
    excerpt: "Building an automated news platform that filters 40+ RSS feeds through Groq AI for relevance, accountability, and Canadian focus.",
    tags: ["Astro", "Cloudflare", "AI"],
    slug: "frostbite-gazette-overview",
    readTime: 7,
    featured: true
  }
];

const tags = [...new Set(posts.flatMap(p => p.tags))];

// Tag colors
const tagColors: Record<string, string> = {
  "NixOS": "var(--base0D)",
  "AI": "var(--base09)",
  "Privacy": "var(--base0B)",
  "Career": "var(--base0E)",
  "Learning": "var(--base0F)",
  "Rust": "var(--base0D)",
  "Infrastructure": "var(--base0E)",
  "Colmena": "var(--base09)",
  "Astro": "var(--base0D)",
  "Cloudflare": "var(--base0B)"
};
---

<Layout
  title="Blog"
  description="Technical writing about development, infrastructure, and AI. Topics include NixOS cluster management, Rust patterns, Kubernetes, and building local-first applications."
>
  <div class="max-w-3xl mx-auto px-6 py-16">
    <!-- Header -->
    <div data-animate="fade-up">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-2xl">✍️</span>
        <h1 class="text-4xl font-bold text-[var(--base07)]">Blog</h1>
      </div>
      <p class="text-sm text-[var(--base04)] mb-4">Writing about development, infrastructure, and learning in public</p>
    </div>

    <!-- Stats Bar -->
    <div class="flex items-center gap-6 mb-8 text-sm" data-animate="fade-up" data-delay="0.05">
      <div class="flex items-center gap-2">
        <span class="text-[var(--base09)]">{posts.length}</span>
        <span class="text-[var(--base04)]">posts</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-[var(--base09)]">{tags.length}</span>
        <span class="text-[var(--base04)]">topics</span>
      </div>
      <div class="ml-auto text-xs text-[var(--base04)]">
        Building in public 🚀
      </div>
    </div>

    <!-- Tags Filter with enhanced UI -->
    <div class="glass p-4 mb-8" data-animate="fade-up" data-delay="0.1">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-sm text-[var(--base04)]">Filter by topic:</span>
        <span class="ml-auto text-xs text-[var(--base04)]">Click to filter</span>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="filter-tag active text-xs px-4 py-2 rounded-full cursor-pointer transition-all duration-200 hover:scale-105 bg-[var(--base0D)] text-[var(--base00)] font-medium">
          All Posts
        </span>
        {tags.map(tag => (
          <span
            class="filter-tag text-xs px-4 py-2 rounded-full cursor-pointer transition-all duration-200 hover:scale-105"
            style="background: var(--base02); color: {tagColors[tag]};"
          >
            #{tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Featured Post -->
    {posts.filter(p => p.featured).slice(0, 1).map((post, i) => (
      <article
        class="glass p-6 mb-6 relative overflow-hidden group hover:shadow-xl transition-all duration-300"
        data-animate="fade-up"
        data-delay={`${0.15 + i * 0.05}`}
      >
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--base09)]/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative">
          <div class="flex items-center gap-2 mb-3">
            <span class="px-2 py-0.5 bg-[var(--base09)] text-[var(--base00)] text-xs font-bold rounded">FEATURED</span>
            <span class="text-xs text-[var(--base04)] flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {post.readTime} min read
            </span>
          </div>
          <h2 class="text-2xl font-bold text-[var(--base07)] mb-3 group-hover:text-[var(--base09)] transition-colors">
            <a href={`/blog/${post.slug}`} class="flex items-center gap-2 group/link">
              {post.title}
              <svg class="w-5 h-5 opacity-0 -translate-x-2 group-hover/link:opacity-100 group-hover/link:translate-x-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </h2>
          <p class="text-sm text-[var(--base05)] mb-4 leading-relaxed">{post.excerpt}</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              {post.tags.map(tag => (
                <span class="text-xs px-2 py-1 bg-[var(--base02)] rounded" style="color: {tagColors[tag]};">
                  #{tag}
                </span>
              ))}
            </div>
            <a href={`/blog/${post.slug}`} class="text-sm text-[var(--base0D)] hover:text-[var(--base09)] transition-colors inline-flex items-center gap-1 group/link">
              Read more
              <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </article>
    ))}

    <!-- Regular Posts -->
    <div class="space-y-4">
      {posts.filter(p => !p.featured).map((post, i) => (
        <article
          class="glass p-5 hover:shadow-lg transition-all duration-300 group"
          data-animate="fade-up"
          data-delay={`${0.2 + i * 0.08}`}
        >
          <div class="flex items-center gap-3 text-xs text-[var(--base04)] mb-2">
            <time>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <span>·</span>
            <span class="flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {post.readTime} min read
            </span>
          </div>
          <h2 class="text-lg font-bold text-[var(--base07)] mb-2 group-hover:text-[var(--base0D)] transition-colors">
            <a href={`/blog/${post.slug}`} class="flex items-center gap-2 group/link">
              {post.title}
              <svg class="w-4 h-4 opacity-0 -translate-x-2 group-hover/link:opacity-100 group-hover/link:translate-x-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </h2>
          <p class="text-sm text-[var(--base05)] mb-3 line-clamp-2">{post.excerpt}</p>
          <div class="flex items-center justify-between">
            <div class="flex gap-1.5">
              {post.tags.map(tag => (
                <span class="text-xs px-2 py-0.5 bg-[var(--base02)] rounded" style="color: {tagColors[tag]};">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Coming Soon Banner -->
    <div class="glass p-6 mt-8 text-center relative overflow-hidden" data-animate="fade-up" data-delay="0.5">
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--base09)]/5 via-transparent to-[var(--base0D)]/5"></div>
      <div class="relative">
        <div class="text-2xl mb-2">🚧</div>
        <h3 class="text-lg font-bold text-[var(--base07)] mb-2">More Coming Soon!</h3>
        <p class="text-sm text-[var(--base04)] mb-4">
          Building in public means sharing the journey, including the messy parts.
          Stay tuned for more posts on NixOS, Rust, and AI development.
        </p>
        <div class="flex items-center justify-center gap-4 text-xs text-[var(--base04)]">
          <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-[var(--base09)] animate-pulse"></span>
            Writing in progress
          </span>
          <span>·</span>
          <span>Subscribe for updates (coming soon)</span>
        </div>
      </div>
    </div>

    <!-- Back Navigation -->
    <div class="mt-8 text-center" data-animate="fade-up" data-delay="0.55">
      <a href="/" class="inline-flex items-center gap-2 text-sm text-[var(--base04)] hover:text-[var(--base0D)] transition-colors group">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
      </a>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

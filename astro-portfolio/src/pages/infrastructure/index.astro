---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Infrastructure - reverb256">
  <section class="min-h-screen px-6 py-12 max-w-6xl mx-auto">
    <div class="mb-12">
      <a href="/" class="text-[var(--base0D)] hover:underline mb-4 inline-block">← Back to Portfolio</a>
      <h1 class="text-4xl font-bold text-[var(--base07)]">Infrastructure Ecosystem</h1>
      <p class="mt-4 text-[var(--base05)]">4-host NixOS mining cluster with AI-powered monitoring and privacy-first local inference.</p>
    </div>

    <!-- Overview Stats -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="glass p-4 text-center">
        <div class="text-3xl font-bold text-[var(--base09)]">4</div>
        <div class="text-xs text-[var(--base05)]">Hosts</div>
      </div>
      <div class="glass p-4 text-center">
        <div class="text-3xl font-bold text-[var(--base09)]">7</div>
        <div class="text-xs text-[var(--base05)]">GPUs</div>
      </div>
      <div class="glass p-4 text-center">
        <div class="text-3xl font-bold text-[var(--base09)]">30+</div>
        <div class="text-xs text-[var(--base05)]">Docs</div>
      </div>
      <div class="glass p-4 text-center">
        <div class="text-3xl font-bold text-[var(--base09)]">50+</div>
        <div class="text-xs text-[var(--base05)]">Justfile Commands</div>
      </div>
    </section>

    <!-- Cluster Map -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--base07)] mb-6">// Mining Cluster</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Zephyr -->
        <div class="glass p-6 border-l-4 border-[var(--base09)]">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-[var(--base07)]">Zephyr</h3>
            <span class="text-xs px-2 py-1 bg-[var(--base02)] rounded text-[var(--base05)]">Main Workstation</span>
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-[var(--base05)]">CPU:</span><span class="text-[var(--base06)]">Ryzen 9 5950X (Zen 3)</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">GPUs:</span><span class="text-[var(--base06)]">RTX 3090 + 3060 Ti</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Location:</span><span class="text-[var(--base06)]">Room 2</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Mining:</span><span class="text-[var(--base06)]">16 CPU threads</span></div>
          </div>
        </div>

        <!-- Nexus -->
        <div class="glass p-6 border-l-4 border-[var(--base0D)]">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-[var(--base07)]">Nexus</h3>
            <span class="text-xs px-2 py-1 bg-[var(--base02)] rounded text-[var(--base05)]">Mining Node</span>
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-[var(--base05)]">CPU:</span><span class="text-[var(--base06)]">Ryzen 9 3900X (Zen 2)</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">GPUs:</span><span class="text-[var(--base06)]">1x NVIDIA</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Location:</span><span class="text-[var(--base06)]">Downstairs</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Mining:</span><span class="text-[var(--base06)]">12 CPU threads</span></div>
          </div>
        </div>

        <!-- Forge -->
        <div class="glass p-6 border-l-4 border-[var(--base0A)]">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-[var(--base07)]">Forge</h3>
            <span class="text-xs px-2 py-1 bg-[var(--base02)] rounded text-[var(--base05)]">Mixed Mining</span>
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-[var(--base05)]">CPU:</span><span class="text-[var(--base06)]">i5-9500 (Coffee Lake)</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">GPUs:</span><span class="text-[var(--base06)]">2x RTX 4060 + 2x RX 5700 XT</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Location:</span><span class="text-[var(--base06)]">Room 1</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Mining:</span><span class="text-[var(--base06)]">GPU only</span></div>
          </div>
        </div>

        <!-- Sentry -->
        <div class="glass p-6 border-l-4 border-[var(--base0B)]">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-[var(--base07)]">Sentry</h3>
            <span class="text-xs px-2 py-1 bg-[var(--base02)] rounded text-[var(--base05)]">CPU Mining</span>
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-[var(--base05)]">CPU:</span><span class="text-[var(--base06)]">Ryzen 7 1700 (Zen 1)</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">GPUs:</span><span class="text-[var(--base06)]">1x AMD</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Location:</span><span class="text-[var(--base06)]">Room 1</span></div>
            <div class="flex justify-between"><span class="text-[var(--base05)]">Mining:</span><span class="text-[var(--base06)]">8 CPU threads</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technologies -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--base07)] mb-6">// Technologies</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- NixOS Stack -->
        <div class="glass p-6">
          <h3 class="text-lg font-bold text-[var(--base0D)] mb-4">NixOS Stack</h3>
          <ul class="space-y-2 text-sm text-[var(--base05)]">
            <li>• <strong class="text-[var(--base06)]">Colmena</strong> — Multi-host deployment</li>
            <li>• <strong class="text-[var(--base06)]">Flake</strong> — Reproducible configs</li>
            <li>• <strong class="text-[var(--base06)]">Justfile</strong> — 50+ automation commands</li>
            <li>• <strong class="text-[var(--base06)]">Distributed builds</strong> — Cross-compilation</li>
            <li>• <strong class="text-[var(--base06)]">CPU tuning</strong> — Per-host microarch</li>
          </ul>
        </div>

        <!-- AI Monitoring -->
        <div class="glass p-6">
          <h3 class="text-lg font-bold text-[var(--base09)] mb-4">AI Monitoring</h3>
          <ul class="space-y-2 text-sm text-[var(--base05)]">
            <li>• <strong class="text-[var(--base06)]">Qwen 3.5-0.8B</strong> — Local inference</li>
            <li>• <strong class="text-[var(--base06)]">pi-agent-core</strong> — Event streaming</li>
            <li>• <strong class="text-[var(--base06)]">KDE Plasmoid</strong> — Dashboard UI</li>
            <li>• <strong class="text-[var(--base06)]">Prometheus</strong> — Metrics store</li>
            <li>• <strong class="text-[var(--base06)]">GPU control</strong> — Auto clock tuning</li>
          </ul>
        </div>

        <!-- Migration -->
        <div class="glass p-6">
          <h3 class="text-lg font-bold text-[var(--base0B)] mb-4">K8s Migration</h3>
          <ul class="space-y-2 text-sm text-[var(--base05)]">
            <li>• <strong class="text-[var(--base06)]">Podman</strong> — Container runtime</li>
            <li>• <strong class="text-[var(--base06)]">GPU scheduling</strong> — Multi-GPU pods</li>
            <li>• <strong class="text-[var(--base06)]">Mining orchestration</strong> — Containerized</li>
            <li>• <strong class="text-[var(--base06)]">In progress</strong> — 9-week roadmap</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--base07)] mb-6">// Running Services</h2>
      <div class="glass p-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-sm font-bold text-[var(--base0D)] mb-3">Monitoring & Control</h3>
            <ul class="space-y-1 text-sm text-[var(--base05)]">
              <li>Prometheus (port 9090) — Hashrate, temp, power metrics</li>
              <li>XMRig API — Mining control with Bearer auth</li>
              <li>lolMiner API — Read-only mining stats</li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-bold text-[var(--base09)] mb-3">Local AI Stack</h3>
            <ul class="space-y-1 text-sm text-[var(--base05)]">
              <li>AI Gateway — OpenAI-compatible API</li>
              <li>CC Router — Anthropic-style API</li>
              <li>llama.cpp — Qwen3.5-0.8B inference server</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Documentation -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--base07)] mb-6">// Documentation</h2>
      <div class="glass p-6">
        <p class="text-sm text-[var(--base05)] mb-4">Comprehensive documentation covering deployment, monitoring, Kubernetes migration, and AI integration.</p>
        <div class="flex flex-wrap gap-2">
          {["Colmena Deployment", "K8s GPU Scheduling", "AI Monitoring", "Failover Implementation", "CI/CD Setup", "Distributed Builds", "Gaming Configs", "LLaMA CPP Roadmap"].map(tag => (
            <span class="text-xs px-2 py-1 bg-[var(--base02)] rounded text-[var(--base05)]">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <a href="/" class="text-[var(--base0D)] hover:underline">← Back to Portfolio</a>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import HeroCluster from '../../components/infrastructure/HeroCluster.astro';
import GlassCard from '../../components/infrastructure/GlassCard.astro';
import Timeline from '../../components/infrastructure/Timeline.astro';
import CodeExplorer from '../../components/infrastructure/CodeExplorer.astro';
import { CLUSTER_DATA } from '../../lib/infrastructure-data';
---

<Layout title="Infrastructure | Reverb256">
  <main class="infrastructure-page">
    <HeroCluster />

    <!-- Intro Section -->
    <section class="intro-section">
      <div class="container">
        <h2 class="section-title">Mining Infrastructure Meets Cloud Native</h2>

        <div class="glass-grid">
          <GlassCard
            title="The Challenge"
            description="Managing 4 NixOS hosts, 8 GPUs across mining and Kubernetes workloads, with centralized configuration and monitoring."
          />
          <GlassCard
            title="The Solution"
            description="A custom NixOS framework with profile-based config management, NFS synchronization, and Kubernetes service mesh for unified cluster operations."
          />
        </div>

        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalCores}</div>
            <div class="stat-label">CPU Cores</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalRAM}</div>
            <div class="stat-label">RAM</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalGPUs}</div>
            <div class="stat-label">GPUs</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalStorage}</div>
            <div class="stat-label">Storage</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Innovation Section -->
    <section class="innovation-section">
      <div class="container">
        <h2 class="section-title">Infrastructure Innovation</h2>

        <div class="glass-grid">
          <GlassCard
            title="NFS Config Sync"
            description="NixOS configurations stored on NFS share. Changes to /etc/nixos propagate to all hosts via auto-mount, enabling single-source-of-truth cluster management."
          />
          <GlassCard
            title="Profile System"
            description="50+ Justfile commands organized by profile (desktop, gaming, k8s, mining). Run 'just desktop' to rebuild desktop environment, 'just k8s' to manage cluster, 'just mining' to control GPU workloads."
          />
          <GlassCard
            title="Custom NixOS Modules"
            description="Local flake with reusable modules: mining.bash (GPU management), llm.nix (vLLM integration), cluster.nix (K8s setup). Composable infrastructure as code."
          />
        </div>
      </div>
    </section>

    <!-- Operations Section -->
    <section class="operations-section">
      <div class="container">
        <h2 class="section-title">Operations & Automation</h2>

        <div class="glass-grid">
          <GlassCard
            title="Automated Deployments"
            description="NixOS rebuilds trigger automatic service restarts. Kubernetes deployments via GitOps-style manifests. Mining operations auto-restart on GPU availability."
          />
          <GlassCard
            title="Service Mesh"
            description="Flannel CNI for pod networking, CoreDNS for service discovery, statefulsets for databases. Prometheus + Grafana for monitoring and alerting."
          />
          <GlassCard
            title="Observability"
            description="Centralized logging with Promtail, metrics collection with Prometheus, visualization in Grafana. Alertmanager for incident response."
          />
        </div>
      </div>
    </section>

    <!-- Capabilities Section -->
    <section class="capabilities-section">
      <div class="container">
        <h2 class="section-title">Cluster Capabilities</h2>

        <div class="glass-grid">
          <GlassCard
            title="Hardware Infrastructure"
            description={`${CLUSTER_DATA.stats.totalCores} CPU cores, ${CLUSTER_DATA.stats.totalRAM} RAM, ${CLUSTER_DATA.stats.totalGPUs} GPUs (${CLUSTER_DATA.hosts.map(h => h.specs.gpus.join(', ')).join(', ')}), ${CLUSTER_DATA.stats.totalStorage} storage across ${CLUSTER_DATA.hosts.length} hosts. Mining capacity: 4 GPUs. Kubernetes capacity: 4 GPUs.`}
          />
          <GlassCard
            title="AI/ML Services"
            description="n8n for AI workflows, Qdrant for vector search, vLLM for local LLM inference, OpenAI-compatible API gateway with middleware (rate limiting, circuit breaker, Redis caching)."
          />
          <GlassCard
            title="Akash Cloud Provider"
            description={`
              <strong>Status:</strong> ${CLUSTER_DATA.akash.status}<br>
              <strong>GPUs:</strong> ${CLUSTER_DATA.akash.gpus.map(g => `${g.model} (${g.vram}) - ${g.status}`).join('<br>')}<br>
              <strong>Storage:</strong> ${CLUSTER_DATA.akash.storage.join(', ')}<br>
              <strong>Endpoints:</strong> ${CLUSTER_DATA.akash.endpoints.provider}, ${CLUSTER_DATA.akash.endpoints.ingress}<br>
              <strong>Active Leases:</strong> ${CLUSTER_DATA.akash.leases}
            `}
          />
        </div>
      </div>
    </section>

    <!-- Timeline Section -->
    <section class="timeline-section">
      <div class="container">
        <h2 class="section-title">Infrastructure Timeline</h2>
        <Timeline milestones={CLUSTER_DATA.timeline} />
      </div>
    </section>

    <!-- Code Explorer Section -->
    <section class="code-explorer-section">
      <div class="container">
        <h2 class="section-title">Code Explorer</h2>
        <CodeExplorer />
      </div>
    </section>
  </main>
</Layout>

<style>
  .infrastructure-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
    color: #e0e0e0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  section {
    padding: 4rem 0;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .glass-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: #667eea;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #a0a0a0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }

    section {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    .glass-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-value {
      font-size: 2rem;
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import HeroCluster from '../../components/infrastructure/HeroCluster.astro';
import GlassCard from '../../components/infrastructure/GlassCard.astro';
import Timeline from '../../components/infrastructure/Timeline.astro';
import CodeExplorer from '../../components/infrastructure/CodeExplorer.astro';
import { CLUSTER_DATA } from '../../lib/infrastructure-data';
---

<Layout title="Infrastructure | Reverb256">
  <!-- Scroll Progress Indicator -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <!-- Section Navigation -->
  <nav class="section-nav" aria-label="Section navigation">
    <button
      class="section-nav-dot active"
      data-section="intro"
      aria-label="Go to introduction section"
      aria-current="page"
    >
      <span class="section-nav-label">Introduction</span>
    </button>
    <button
      class="section-nav-dot"
      data-section="innovation"
      aria-label="Go to innovation section"
    >
      <span class="section-nav-label">Innovation</span>
    </button>
    <button
      class="section-nav-dot"
      data-section="operations"
      aria-label="Go to operations section"
    >
      <span class="section-nav-label">Operations</span>
    </button>
    <button
      class="section-nav-dot"
      data-section="capabilities"
      aria-label="Go to capabilities section"
    >
      <span class="section-nav-label">Capabilities</span>
    </button>
    <button
      class="section-nav-dot"
      data-section="timeline"
      aria-label="Go to timeline section"
    >
      <span class="section-nav-label">Timeline</span>
    </button>
    <button
      class="section-nav-dot"
      data-section="code"
      aria-label="Go to code explorer section"
    >
      <span class="section-nav-label">Code</span>
    </button>
  </nav>

  <main class="infrastructure-page">
    <HeroCluster />

    <!-- Intro Section -->
    <section class="intro-section" data-section="intro">
      <div class="container">
        <h2 class="section-title">Mining Infrastructure Meets Cloud Native</h2>

        <div class="glass-grid">
          <GlassCard
            title="The Challenge"
            description="Managing 4 NixOS hosts, 8 GPUs across mining and Kubernetes workloads, with centralized configuration and monitoring."
          />
          <GlassCard
            title="The Solution"
            description="A custom NixOS framework with profile-based config management, NFS synchronization, and Kubernetes service mesh for unified cluster operations."
          />
        </div>

        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalCores}</div>
            <div class="stat-label">CPU Cores</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalRAM}</div>
            <div class="stat-label">RAM</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalGPUs}</div>
            <div class="stat-label">GPUs</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">{CLUSTER_DATA.stats.totalStorage}</div>
            <div class="stat-label">Storage</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Innovation Section -->
    <section class="innovation-section" data-section="innovation">
      <div class="container">
        <h2 class="section-title">Infrastructure Innovation</h2>

        <div class="glass-grid">
          <GlassCard
            title="NFS Config Sync"
            description="NixOS configurations stored on NFS share. Changes to /etc/nixos propagate to all hosts via auto-mount, enabling single-source-of-truth cluster management."
          />
          <GlassCard
            title="Profile System"
            description="50+ Justfile commands organized by profile (desktop, gaming, k8s, mining). Run 'just desktop' to rebuild desktop environment, 'just k8s' to manage cluster, 'just mining' to control GPU workloads."
          />
          <GlassCard
            title="Custom NixOS Modules"
            description="Local flake with reusable modules: mining.bash (GPU management), llm.nix (vLLM integration), cluster.nix (K8s setup). Composable infrastructure as code."
          />
        </div>
      </div>
    </section>

    <!-- Operations Section -->
    <section class="operations-section" data-section="operations">
      <div class="container">
        <h2 class="section-title">Operations & Automation</h2>

        <div class="glass-grid">
          <GlassCard
            title="Automated Deployments"
            description="NixOS rebuilds trigger automatic service restarts. Kubernetes deployments via GitOps-style manifests. Mining operations auto-restart on GPU availability."
          />
          <GlassCard
            title="Service Mesh"
            description="Flannel CNI for pod networking, CoreDNS for service discovery, statefulsets for databases. Prometheus + Grafana for monitoring and alerting."
          />
          <GlassCard
            title="Observability"
            description="Centralized logging with Promtail, metrics collection with Prometheus, visualization in Grafana. Alertmanager for incident response."
          />
        </div>
      </div>
    </section>

    <!-- Capabilities Section -->
    <section class="capabilities-section" data-section="capabilities">
      <div class="container">
        <h2 class="section-title">Cluster Capabilities</h2>

        <div class="glass-grid">
          <GlassCard
            title="Hardware Infrastructure"
            description={`${CLUSTER_DATA.stats.totalCores} CPU cores, ${CLUSTER_DATA.stats.totalRAM} RAM, ${CLUSTER_DATA.stats.totalGPUs} GPUs (${CLUSTER_DATA.hosts.map(h => h.specs.gpus.join(', ')).join(', ')}), ${CLUSTER_DATA.stats.totalStorage} storage across ${CLUSTER_DATA.hosts.length} hosts. Mining capacity: 4 GPUs. Kubernetes capacity: 4 GPUs.`}
          />
          <GlassCard
            title="AI/ML Services"
            description="n8n for AI workflows, Qdrant for vector search, vLLM for local LLM inference, OpenAI-compatible API gateway with middleware (rate limiting, circuit breaker, Redis caching)."
          />
          <GlassCard
            title="Akash Cloud Provider"
            description={`
              <strong>Status:</strong> ${CLUSTER_DATA.akash.status}<br>
              <strong>GPUs:</strong> ${CLUSTER_DATA.akash.gpus.map(g => `${g.model} (${g.vram}) - ${g.status}`).join('<br>')}<br>
              <strong>Storage:</strong> ${CLUSTER_DATA.akash.storage.join(', ')}<br>
              <strong>Endpoints:</strong> ${CLUSTER_DATA.akash.endpoints.provider}, ${CLUSTER_DATA.akash.endpoints.ingress}<br>
              <strong>Active Leases:</strong> ${CLUSTER_DATA.akash.leases}
            `}
          />
        </div>
      </div>
    </section>

    <!-- Timeline Section -->
    <section class="timeline-section" data-section="timeline">
      <div class="container">
        <h2 class="section-title">Infrastructure Timeline</h2>
        <Timeline milestones={CLUSTER_DATA.timeline} />
      </div>
    </section>

    <!-- Code Explorer Section -->
    <section class="code-explorer-section" data-section="code">
      <div class="container">
        <h2 class="section-title">Code Explorer</h2>
        <CodeExplorer />
      </div>
    </section>
  </main>
</Layout>

<script>
  import { initInfrastructureAnimations } from '../../lib/animations';

  // Initialize animations
  initInfrastructureAnimations();

  // Scroll progress indicator
  const updateScrollProgress = () => {
    const scrollProgress = document.querySelector('.scroll-progress') as HTMLElement;
    if (!scrollProgress) return;

    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const scrollPercent = (scrollTop / docHeight) * 100;

    scrollProgress.style.width = `${scrollPercent}%`;
  };

  // Section navigation
  const sections = document.querySelectorAll('section');
  const navDots = document.querySelectorAll('.section-nav-dot');

  // Update active section based on scroll position
  const updateActiveSection = () => {
    const scrollPosition = window.scrollY + window.innerHeight / 2;

    sections.forEach((section, index) => {
      const sectionTop = (section as HTMLElement).offsetTop;
      const sectionBottom = sectionTop + (section as HTMLElement).offsetHeight;

      if (scrollPosition >= sectionTop && scrollPosition < sectionBottom) {
        // Remove active class from all dots
        navDots.forEach(dot => {
          dot.classList.remove('active');
          dot.removeAttribute('aria-current');
        });

        // Add active class to current dot
        const currentDot = navDots[index];
        if (currentDot) {
          currentDot.classList.add('active');
          currentDot.setAttribute('aria-current', 'page');
        }
      }
    });
  };

  // Smooth scroll to section when dot is clicked
  navDots.forEach(dot => {
    dot.addEventListener('click', () => {
      const sectionId = dot.getAttribute('data-section');
      if (!sectionId) return;

      let sectionSelector = '';
      switch (sectionId) {
        case 'intro':
          sectionSelector = '.intro-section';
          break;
        case 'innovation':
          sectionSelector = '.innovation-section';
          break;
        case 'operations':
          sectionSelector = '.operations-section';
          break;
        case 'capabilities':
          sectionSelector = '.capabilities-section';
          break;
        case 'timeline':
          sectionSelector = '.timeline-section';
          break;
        case 'code':
          sectionSelector = '.code-explorer-section';
          break;
      }

      const targetSection = document.querySelector(sectionSelector);
      if (targetSection) {
        const offsetTop = (targetSection as HTMLElement).offsetTop;
        window.scrollTo({
          top: offsetTop,
          behavior: 'smooth'
        });
      }
    });
  });

  // Throttled scroll listener for better performance
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateScrollProgress();
        updateActiveSection();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  // Initial updates
  updateScrollProgress();
  updateActiveSection();
</script>

<style>
  /* Scroll Progress Indicator */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    min-width: 3px; /* Ensure visible even at 0% progress */
    height: 3px;
    background: linear-gradient(90deg, #ff9f5c 0%, #6ee7de 100%);
    z-index: 9999;
    transition: width 0.1s ease-out;
    will-change: width;
  }

  /* Section Navigation */
  .section-nav {
    position: fixed;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    z-index: 1000;
    opacity: 0;
    animation: fade-in-nav 0.5s ease-out 1s forwards;
  }

  @keyframes fade-in-nav {
    to { opacity: 1; }
  }

  .section-nav-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.3);
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    will-change: transform, background;
  }

  .section-nav-dot:hover {
    background: rgba(255, 255, 255, 0.4);
    transform: scale(1.2);
  }

  .section-nav-dot.active {
    background: #ff9f5c;
    border-color: #ff9f5c;
    transform: scale(1.3);
    box-shadow: 0 0 10px rgba(255, 159, 92, 0.5);
  }

  .section-nav-label {
    position: absolute;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(15, 23, 42, 0.9);
    color: #e0e0e0;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .section-nav-dot:hover .section-nav-label {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .section-nav {
      display: none; /* Hide on mobile for better UX */
    }
  }

  .infrastructure-page {
    min-height: 100vh;
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.9)),
      linear-gradient(rgba(147, 51, 234, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(147, 51, 234, 0.1) 1px, transparent 1px);
    background-size: 100% 100%, 50px 50px, 50px 50px;
    background-position: 0 0, 0 0, 0 0;
    background-attachment: fixed;
    color: #e0e0e0;
    scroll-behavior: smooth;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  section {
    padding: 4rem 0;
    min-height: 50vh; /* Ensure sections have enough height for scroll storytelling */
  }

  /* First section should be taller for hero effect */
  .intro-section {
    min-height: 80vh;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    background: linear-gradient(135deg, #ff9f5c 0%, #6ee7de 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .glass-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: #ff9f5c;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #a0a0a0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }

    section {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    .glass-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-value {
      font-size: 2rem;
    }

    /* Cluster 3D Visualization Styles */
    .cluster-3d {
      position: absolute;
      width: 100%;
      height: 100%;
      perspective: 1000px;
      overflow: hidden;
    }

    .cluster-scene {
      position: absolute;
      width: 100%;
      height: 100%;
      transform-style: preserve-3d;
      transition: transform 0.1s linear;
      will-change: transform;
    }

    .cluster-node {
      position: absolute;
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgb(255, 159, 92) 0%, rgb(110, 231, 222) 100%);
      border: 2px solid rgba(255, 159, 92, 0.5);
      box-shadow: 0 0 20px rgba(255, 159, 92, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      user-select: none;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .cluster-node:hover {
      transform: translate3d(var(--node-x), var(--node-y), var(--node-z)) translate(-50%, -50%) scale(1.2) !important;
      box-shadow: 0 0 30px rgba(255, 159, 92, 0.6);
    }

    .cluster-node-content {
      text-align: center;
      color: white;
      font-size: 12px;
      font-weight: bold;
    }

    .cluster-node-name {
      display: block;
    }

    .cluster-node-gpus {
      font-size: 10px;
      opacity: 0.8;
    }

    .particle {
      position: absolute;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(110, 231, 222, 0.8);
      box-shadow: 0 0 10px rgba(110, 231, 222, 0.5);
      pointer-events: none;
      will-change: transform, opacity;
    }
  }
</style>

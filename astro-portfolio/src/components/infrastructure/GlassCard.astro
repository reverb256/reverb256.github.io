---
/**
 * GlassCard.astro - Reusable glass morphism card component
 *
 * Features:
 * - Glass morphism effect with backdrop blur
 * - Optional icon display
 * - Hover animation with subtle lift
 * - Styled content (p, ul, li)
 * - Compatible with base24 color system
 */

interface Props {
  title: string;
  icon?: string;
  class?: string;
}

const { title, icon, class: className } = Astro.props;
---

<div class={"glass-card " + (className || "")}>
  {icon && (
    <div class="card-icon" aria-hidden="true">
      {icon}
    </div>
  )}
  <h3 class="card-title">{title}</h3>
  <div class="card-content">
    <slot />
  </div>
</div>

<style>
  /* ═════════════════════════════════════════════════════════════
     GLASS CARD STYLES - Glass Morphism Design System
     ═════════════════════════════════════════════════════════════ */

  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 2rem;
    transition: transform var(--duration-normal, 300ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow var(--duration-normal, 300ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .glass-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.4),
      0 0 32px var(--glow-color, rgba(255, 159, 92, 0.4));
  }

  /* ═════════════════════════════════════════════════════════════
     CARD ICON
     ═════════════════════════════════════════════════════════════ */

  .card-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  /* ═════════════════════════════════════════════════════════════
     CARD TITLE
     ═════════════════════════════════════════════════════════════ */

  .card-title {
    color: var(--text-primary, var(--base07));
    font-size: var(--text-xl, 1.25rem);
    font-weight: 700;
    margin: 0 0 1rem 0;
    line-height: 1.3;
  }

  /* ═════════════════════════════════════════════════════════════
     CARD CONTENT
     ═════════════════════════════════════════════════════════════ */

  .card-content {
    color: var(--text-secondary, var(--base06));
    font-size: var(--text-base, 1rem);
    line-height: 1.6;
  }

  /* Paragraph styling */
  .card-content p {
    margin: 0 0 1rem 0;
  }

  .card-content p:last-child {
    margin-bottom: 0;
  }

  /* List styling */
  .card-content ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .card-content li {
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: color var(--duration-fast, 150ms) var(--ease-out);
  }

  .card-content li:last-child {
    border-bottom: none;
  }

  .card-content li:hover {
    color: var(--accent-primary, var(--base09));
  }

  /* ═════════════════════════════════════════════════════════════
     REDUCED MOTION
     ═════════════════════════════════════════════════════════════ */

  @media (prefers-reduced-motion: reduce) {
    .glass-card {
      transition: none;
    }

    .glass-card:hover {
      transform: none;
    }
  }

  /* ═════════════════════════════════════════════════════════════
     RESPONSIVE ADJUSTMENTS
     ═════════════════════════════════════════════════════════════ */

  @media (max-width: 768px) {
    .glass-card {
      padding: 1.5rem;
    }

    .card-icon {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .card-title {
      font-size: var(--text-lg, 1.125rem);
      margin-bottom: 0.75rem;
    }

    .card-content {
      font-size: var(--text-sm, 0.875rem);
    }
  }
</style>
